  "keyFeatures": [
    "Multi-language support for Python and .NET with consistent APIs",
    "Graph-based workflow orchestration with streaming and checkpointing",
    "Flexible middleware system for request/response processing",
    "Support for multiple LLM providers (OpenAI, Azure, Anthropic, etc.)",
    "Built-in OpenTelemetry integration for observability",
    "Human-in-the-loop capabilities and tool approval workflows",
    "Interactive DevUI for development and debugging",
    "Agent-to-Agent (A2A) protocol for distributed systems"
  ],
  "publicApiSurface": [
    "Agent / AIAgent - Core agent abstraction",
    "ChatClient / IChatClient - Chat client interface",
    "Tool / AITool - Function tool definitions",
    "Middleware - AgentMiddleware, ChatMiddleware, FunctionMiddleware",
    "AgentSession / AgentSession - Conversation state management",
    "Workflow / WorkflowBuilder - Graph-based orchestration",
    "WorkflowExecutor / Executor - Workflow execution units",
    "ContextProvider / AIContextProvider - Memory and context injection",
    "OpenAI providers - OpenAIChatClient, AzureOpenAIResponsesClient",
    "Anthropic providers - AnthropicChatClient, ClaudeClient",
    "Azure integrations - AzureAIChatClient, AzureAISearchProvider",
    "MCP tools - MCPStdioTool, MCPWebsocketTool",
    "Checkpoint storage - FileCheckpointStorage, InMemoryCheckpointStorage",
    "Telemetry - OpenTelemetry integration for distributed tracing"
  ]
}
